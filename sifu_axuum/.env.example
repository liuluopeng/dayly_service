# 开发环境配置示例
# 复制此文件为 .env 并根据需要修改

# 数据库配置
DATABASE_URL=postgres://dbadmin:dbadmin@0.0.0.0:5432/dayly_db
PG_HOST=0.0.0.0
PG_PORT=5432
PG_USER=dbadmin
PG_PASSWORD=dbadmin
PG_DATABASE=dayly_db

# JWT 配置
JWT_SECRET=hahah

# 日志配置
RUST_LOG="sqlx::query=error,tower_http=debug,info"

# 缓存目录
CACHE_DIR="cache"

# WebDAV 配置
WEBDAV_ROOT_DIR="data"

# 应用环境: development 或 production
# development: 使用 23001 端口
# production: 使用 23000 端口
ENV=development

# 服务器配置
# HOST 默认为 127.0.0.1
# PORT 默认为 23000，但在 development 环境下会自动使用 23001
# HOST=0.0.0.0
# PORT=23000